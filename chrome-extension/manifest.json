{
  "manifest_version": 3,
  "name": "INTERLOCK · Deepfake-CEO Defense for Google Meet",
  "short_name": "INTERLOCK",
  "version": "1.0.0",
  "description": "Real-time deepfake detection on every Google Meet call where money moves. Sub-300ms detect latency, FIDO2 dual co-signature on every irreversible action.",
  "minimum_chrome_version": "121",
  "icons": {
    "16": "icons/interlock-16.png",
    "32": "icons/interlock-32.png",
    "48": "icons/interlock-48.png",
    "128": "icons/interlock-128.png"
  },
  "action": {
    "default_title": "INTERLOCK · CFO Wire-Fraud Defense",
    "default_popup": "src/popup/index.html"
  },
  "background": {
    "service_worker": "src/background/sw.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "permissions": [
    "tabCapture",
    "sidePanel",
    "storage",
    "offscreen",
    "scripting"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://interlock-mu.vercel.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["src/content/meet-hook.js", "src/content/cinematic.js"],
      "css": ["src/content/meet-overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/sidepanel/*", "src/offscreen/*", "icons/*"],
      "matches": ["https://meet.google.com/*"]
    }
  ]
}
